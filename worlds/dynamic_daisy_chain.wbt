#VRML_SIM R2024a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/robots/dji/protos/DJIMavic2Pro.proto"

WorldInfo {
  title "Dynamic Daisy Chain — Production tunnel swarm (Track 2)"
  info [
    "200 m depth axis (+Z), 10 m wide heterogeneous 5-drone daisy chain"
    "Emitter: controllers/dynamic_daisy_emitter → ws://127.0.0.1:8765 (60 Hz) + motion targets JSON"
    "Relay1 scripted fail @118s (emergent replan). Requires: pip install -r requirements-mockdata.txt"
  ]
  gravity 0 -9.81 0
  physics "ODE"
  basicTimeStep 16
  FPS 60
}

Viewpoint {
  position 28 38 105
  orientation 0.05 0.99 0.12 3.48
}

TexturedBackground {
  texture "noon_cloudy_countryside"
}

RectangleArena {
  floorSize 80 240
  floorTileSize 10
  wallHeight 2
  wallThickness 0.15
  wallColor 0.35 0.35 0.38
}

DirectionalLight {
  direction 0.35 -1 0.25
  intensity 1.35
  castShadows TRUE
}

PointLight {
  location 0 14 8
  intensity 1.1
  radius 140
}

