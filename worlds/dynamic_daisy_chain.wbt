# --- Heterogeneous swarm (DEF for Supervisor telemetry) ---
DEF DRONE0 DJIMavic2Pro {
  translation 0 2.2 4
  rotation 0 1 0 0
  name "drone_0"
  controller "dynamic_daisy_drone"
  controllerArgs ["--id", "drone_0", "--profile", "explorer"]
  customData "explorer"
}
DEF DRONE1 DJIMavic2Pro {
  translation 3 2.2 10
  rotation 0 1 0 0.35
  name "drone_1"
  controller "dynamic_daisy_drone"
  controllerArgs ["--id", "drone_1", "--profile", "relay"]
  customData "relay"
}
DEF DRONE2 DJIMavic2Pro {
  translation -3.2 2.2 14
  rotation 0 1 0 -0.25
  name "drone_2"
  controller "dynamic_daisy_drone"
  controllerArgs ["--id", "drone_2", "--profile", "indoor"]
  customData "indoor"
}
DEF DRONE3 DJIMavic2Pro {
  translation 4.2 2.2 8
  rotation 0 1 0 0.5
  name "drone_3"
  controller "dynamic_daisy_drone"
  controllerArgs ["--id", "drone_3", "--profile", "heavy"]
  customData "heavy"
}
DEF DRONE4 DJIMavic2Pro {
  translation -4.0 2.2 6
  rotation 0 1 0 -0.45
  name "drone_4"
  controller "dynamic_daisy_drone"
  controllerArgs ["--id", "drone_4", "--profile", "backup"]
  customData "backup"
}

Robot {
  translation 0 0 -6
  name "dynamic_daisy_emitter"
  supervisor TRUE
  controller "dynamic_daisy_emitter"
  children []
}
