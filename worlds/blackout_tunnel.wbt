#VRML_SIM R2024a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2024a/projects/objects/robots/dji/protos/DJIMavic2Pro.proto"
EXTERNPROTO "victim.proto"

WorldInfo {
  title "Track 2 Blackout Tunnel — 5-drone SAR swarm (ROS 2 Humble)"
  info [
    "Tunnel fog + 10 YOLO-style victims + Vertex / relay chain (drone0..drone4)"
    "ROS 2: ros2 launch endendend_launch swarm_track2_launch.py"
    "Webots-only sim services: /webots_supervisor/kill_drone + /webots_supervisor/inject_loss (std_srvs/Empty)"
    "Packaged world + protos: share/endendend_launch/worlds/"
  ]
  gravity 0 -9.81 0
  physics "ODE"
  basicTimeStep 16
  FPS 60
}

Viewpoint {
  position 0 55 120
  orientation 0.707 0.707 0 3.14159
}

TexturedBackground {
  texture "noon_cloudy_countryside"
}

Fog {
  color 0.08 0.08 0.14
  visibilityRange 32
}

RectangleArena {
  floorSize 200 200
  floorTileSize 10
  wallHeight 5
  wallThickness 0.2
  wallColor 0.45 0.45 0.48
}

DirectionalLight {
  direction 0.5 -1 0.5
  intensity 1.2
  castShadows TRUE
}

PointLight {
  location 0 28 0
  intensity 0.65
  radius 120
}

# --- Tunnel shell (radio / LOS metaphor): long concrete corridor ---
DEF TUNNEL_WALL_LEFT Solid {
  translation -6 2.5 60
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.42 0.42 0.44
        roughness 0.82
        metalness 0.0
      }
      geometry Box {
        size 1 5 120
      }
    }
  ]
  boundingObject Box {
    size 1 5 120
  }
  physics NULL
}

DEF TUNNEL_WALL_RIGHT Solid {
  translation 6 2.5 60
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.4 0.42
        roughness 0.82
        metalness 0.0
      }
      geometry Box {
        size 1 5 120
      }
    }
  ]
  boundingObject Box {
    size 1 5 120
  }
  physics NULL
}

DEF TUNNEL_FLOOR Solid {
  translation 0 0.05 60
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.32 0.3 0.28
        roughness 0.95
        metalness 0.0
      }
      geometry Box {
        size 11 0.1 120
      }
    }
  ]
  boundingObject Box {
    size 11 0.1 120
  }
  physics NULL
}

# --- 5 drones (DEF DRONE0..4 for Webots supervisor failure injection) ---

DEF DRONE0 DJIMavic2Pro {
  translation 0 2 50
  rotation 0 1 0 0
  name "drone_0"
  controller "swarm_controller"
  controllerArgs [
    "--id"
    "drone_0"
    "--port"
    "9001"
    "--ros2-vision"
  ]
  customData "drone_0"
}

DEF DRONE1 DJIMavic2Pro {
  translation 10 2 40
  rotation 0 1 0 0
  name "drone_1"
  controller "swarm_controller"
  controllerArgs [
