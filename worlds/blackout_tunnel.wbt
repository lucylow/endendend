# --- Blackout rubble / hazards (legacy Track 2 props) ---

Solid {
  translation 50 0 50
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.3
        metalness 0.5
      }
      geometry Box {
        size 20 15 20
      }
    }
  ]
  name "collapsed_building"
  boundingObject Box {
    size 20 15 20
  }
  physics Physics {
    density 2000
  }
}

Solid {
  translation 60 0 60
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.4 0.4
      }
      geometry Box {
        size 15 10 15
      }
    }
  ]
  name "rubble_pile"
  boundingObject Box {
    size 15 10 15
  }
  physics Physics {
    density 1500
  }
}

Solid {
  translation -50 0 50
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.2 0.2
      }
      geometry Box {
        size 30 8 5
      }
    }
  ]
  name "tunnel_entrance"
  boundingObject Box {
    size 30 8 5
  }
  physics Physics {
    density 2500
  }
}

Solid {
  translation 30 0.1 80
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 0 0
        transparency 0.5
      }
      geometry Box {
        size 40 0.2 40
      }
    }
  ]
  name "hazard_zone"
}

# --- Webots supervisor (failure injection in-sim; optional rclpy) ---
Robot {
  translation 0 3 -25
  name "blackout_supervisor"
  controller "supervisor_controller"
  supervisor TRUE
}
